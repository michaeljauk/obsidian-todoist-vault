{
  "name": "obsidian-todoist-vault",
  "version": "1.0.0",
  "description": "Syncs Todoist tasks to markdown files in your Obsidian vault",
  "main": "main.js",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "preinstall": "node -e \"if (!/bun/.test(process.env.npm_config_user_agent ?? '')) { console.error('\\nError: use bun to install dependencies.\\n  bun install\\n'); process.exit(1) }\"",
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Michael Jauk",
  "license": "MIT",
  "dependencies": {
    "@doist/todoist-api-typescript": "7.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "obsidian": "latest",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0"
  }
}
